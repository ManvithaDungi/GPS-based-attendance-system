# Example environment variables for backend
# Copy to .env and fill in real values before starting the backend.

# App
PORT=3000
NODE_ENV=development

# Database — localhost when running backend on host; postgres hostname when using Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gps_attendance_system
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/gps_attendance_system

# SMTP (required for sending real emails)
# Use your real SMTP provider; do NOT use mailtrap if you prefer real SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password
SUPPORT_EMAIL=manvitha3626@gmail.com


