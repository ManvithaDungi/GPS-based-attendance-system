# Example environment variables for backend
# Copy to .env and fill in real values before starting the backend.

# App
PORT=3000
NODE_ENV=development

# Database (example - keep existing values if you already use a .env)
DATABASE_URL=postgresql://user:password@postgres:5432/indazone

# SMTP (required for sending real emails)
# Use your real SMTP provider; do NOT use mailtrap if you prefer real SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password
SUPPORT_EMAIL=manvitha3626@gmail.com

# Optional: disable email sending by setting a flag (for local dev)
# DISABLE_EMAILS=false
