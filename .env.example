# Database (host machine / local dev — use localhost)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gps_attendance_system
# Same as DATABASE_URL for local Postgres (no pooler). Docker Compose sets @postgres:5432 instead.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/gps_attendance_system

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Docker)
POSTGRES_DB=gps_attendance_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Mobile API
EXPO_PUBLIC_API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:8081,http://localhost:5173,https://gps-based-attendance-system-khaki.vercel.app,https://gps-based-attendance-system-j4mc.vercel.app